{
  "name": "nudge",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @nudge/api dev",
    "dev:worker": "pnpm --filter @nudge/worker dev",
    "dev:web": "pnpm --filter @nudge/web dev",
    "start:api": "pnpm --filter @nudge/api start",
    "start:worker": "pnpm --filter @nudge/worker start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0"
  },
  "packageManager": "pnpm@9.14.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
