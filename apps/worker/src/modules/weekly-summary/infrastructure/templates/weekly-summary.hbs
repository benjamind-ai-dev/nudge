<!doctype html>
<html>
  <body style="margin:0;padding:0;background:#f3f5f9;font-family:Arial,sans-serif;color:#0d1b3d;">
    <table width="100%" cellpadding="0" cellspacing="0" style="padding:24px 0;">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:8px;overflow:hidden;">
            <tr>
              <td style="padding:24px;background:#0d1b3d;color:#ffffff;font-size:18px;font-weight:600;">Nudge — weekly summary</td>
            </tr>
            <tr>
              <td style="padding:24px;">
                <p style="margin:0 0 8px 0;color:#52607a;font-size:13px;">Week of {{weekStartsAt}}</p>
                <h1 style="margin:0 0 16px 0;font-size:20px;color:#0d1b3d;">{{businessName}}</h1>
                {{#if aiParagraph}}
                  <p style="font-size:16px;font-weight:600;line-height:1.5;color:#0d1b3d;margin:0 0 24px 0;">{{aiParagraph}}</p>
                {{/if}}
                <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:24px;">
                  <tr>
                    <td style="padding:12px;background:#f3f5f9;border-radius:6px;font-size:14px;">
                      <strong>Recovered this week:</strong> ${{recoveredThisWeekUsd}} ({{recoveryDeltaPct}})<br/>
                      <strong>Invoices collected:</strong> {{invoicesCollectedCount}}<br/>
                      {{#if avgDaysToPayThisWeek}}<strong>Avg days to pay:</strong> {{avgDaysToPayThisWeek}} (4-wk avg {{avgDaysToPayTrailing4Weeks}})<br/>{{/if}}
                      <strong>Active sequences:</strong> {{activeSequencesCount}}
                    </td>
                  </tr>
                </table>
                {{#if hasOverdueRows}}
                <h2 style="font-size:16px;color:#0d1b3d;margin:0 0 12px 0;">Top overdue invoices</h2>
                <table width="100%" cellpadding="8" cellspacing="0" style="border-collapse:collapse;font-size:14px;">
                  <thead>
                    <tr style="background:#f3f5f9;text-align:left;">
                      <th>Customer</th><th>Amount</th><th>Days overdue</th><th>Step</th>
                    </tr>
                  </thead>
                  <tbody>
                    {{#each top5OverdueInvoices}}
                      <tr style="border-bottom:1px solid #e6e9f0;">
                        <td>{{this.customerName}}</td>
                        <td>${{this.amountUsd}}</td>
                        <td>{{this.daysOverdue}}</td>
                        <td>{{#if this.currentSequenceStep}}{{this.currentSequenceStep}}{{else}}—{{/if}}</td>
                      </tr>
                    {{/each}}
                  </tbody>
                </table>
                {{/if}}
                <p style="margin:24px 0 0 0;">
                  <a href="{{dashboardUrl}}" style="background:#1e40af;color:#ffffff;padding:10px 16px;border-radius:6px;text-decoration:none;font-weight:600;">View full report →</a>
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
